{
    // General Settings

    // Position TOP
    "layer": "top",
    "margin-top": 0,
    "margin-bottom": 0,

    "layer": "top",
    "height": 40,
    "margin-left": 0,
    "margin-right": 0,    
    "spacing": 0,

    // Load Modules
    "include": ["~/.config/waybar/modules.json"],

    // Modules Left
    "modules-left": [
        "custom/appmenu",
        "custom/wallpaper",
        // "custom/waybarthemes",          
        "wlr/taskbar",
        "group/quicklinks",
        "hyprland/window"
    ],

    // Modules Center
    "modules-center": [
        "hyprland/workspaces"
    ],

    // Modules Right    
    "modules-right": [
        "hyprland/submap",
        "tray",
        "hyprland/language",
        "pulseaudio",
        "bluetooth",
        "battery", 
        "group/hardware",
        "network",
        "custom/exit",
        "clock"
    ],

    // Group Quicklinks
    "group/quicklinks": {
        "orientation": "horizontal",
        "modules": [
            "custom/filemanager",
            "custom/windowsvm"
         ]
    },

    // Group Hardware
    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "disk",
            "cpu",
            "memory"
        ]
    }
}

